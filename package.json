{
  "name": "crts",
  "version": "1.1.2",
  "description": "🔧 A CLI tool for Setting up my rollup + typescript library",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "crts": "dist/index.js"
  },
  "files": [
    "src",
    "dist",
    "template/src",
    "template/package.json",
    "template/rollup.config.ts",
    "template/tsconfig.json"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "rimraf dist && tsc",
    "lint": "oxlint --fix src __tests__ template",
    "pretest": "npm run build",
    "test": "node --test __tests__/*.test.ts",
    "prepublishOnly": "pnpm build",
    "release": "pnpx standard-version && git push --follow-tags && pnpm publish"
  },
  "keywords": [
    "cli",
    "rollup",
    "typescript",
    "library"
  ],
  "author": "Michael Wang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EastSun5566/crts"
  },
  "homepage": "https://github.com/EastSun5566/crts",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxlint": "^1.73.0",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2"
  }
}
